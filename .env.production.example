# Production environment for gerecseingatlan.hu
# Copy to .env.local on the VPS and fill in real values.
#
# KNOWN ISSUES (fix before going live):
#   - NODE_ENV and PORT must be set explicitly
#   - DATABASE_URL must use = not : in the connection string
#   - VITE_GA4_ID must be set for Google Analytics to work (baked into build)

# ─── Server ─────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Database (Supabase Transaction pooler) ─────────────────
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ─── SMTP (for contact form emails) ─────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=info@gerecseingatlan.hu
SMTP_PASS=your-smtp-password

# ─── Email recipient for contact form ────────────────────────
EMAIL_TO=info@gerecseingatlan.hu

# ─── Google Analytics 4 (VITE_ prefix = baked into frontend build) ──
VITE_GA4_ID=G-XXXXXXXXXX

# ─── Property feed (server-side only, semi-sensitive) ────────
INGATLAN_XML_URL=https://ingatlanszoftver.hu/export/XXXX-XXXXXXXXX.xml

# ─── Admin seed credentials ─────────────────────────────────
ADMIN_EMAIL=admin@gerecseingatlan.hu
ADMIN_PASSWORD=change-me-immediately

# ─── Public site URL (used in emails) ───────────────────────
SITE_URL=https://gerecseingatlan.hu
