# Server configuration
NODE_ENV=development
PORT=8080

# SMTP configuration (for contact form emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# Email recipient for contact form submissions
EMAIL_TO=recipient@example.com

# Google Analytics 4 (client-side, must be prefixed with VITE_)
VITE_GA4_ID=G-XXXXXXXXXX

# Ingatlan Forrás 9 XML feed URL (server-side only, NOT exposed to client)
# Contains unique token — treat as semi-sensitive
INGATLAN_XML_URL=https://ingatlanszoftver.hu/export/XXXX-XXXXXXXXX.xml

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/gerecseingatlan

# Admin seed credentials (used by npm run db:seed)
ADMIN_EMAIL=admin@gerecseingatlan.hu
ADMIN_PASSWORD=change-me-immediately

# From address for admin emails
FROM_EMAIL=noreply@gerecseingatlan.hu

# Public site URL (used in emails for login links etc.)
SITE_URL=https://gerecseingatlan.hu
